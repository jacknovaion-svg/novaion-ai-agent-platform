APP_NAME="NOVAION AI Agent Platform"
APP_ENV=development

# Local frontend origins. In production, replace with your Vercel/custom domains.
# Example: https://novaion-web.vercel.app,https://www.novaion.ai
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Supabase/PostgreSQL connection string for SQLAlchemy + psycopg.
# Example: postgresql+psycopg://postgres:[PASSWORD]@[HOST]:5432/postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/novaion

# Keep false for stable customer demos. Set true to try real Playwright scraping.
ENABLE_LIVE_SCRAPING=false
# Best Buy is disabled by default because its site is unstable on hosted Playwright.
ENABLE_BESTBUY_SCRAPING=false
ADAPTER_TIMEOUT_SECONDS=60
PLAYWRIGHT_HEADLESS=true

# V1 has no authentication flow. This demo email is used for preferences and saved searches.
DEFAULT_USER_EMAIL=demo@novaion.ai

# Site Hunter V1 local search mode:
# - No API key is required for the default public DuckDuckGo HTML discovery path.
# - SEARCH_ENGINE_API_KEY is reserved for a future paid/official search provider.
# - Crexi is search-engine-backed discovery only; it is not an official Crexi API.
SITE_HUNTER_SEARCH_PROVIDER=duckduckgo_html
SEARCH_ENGINE_API_KEY=

# Site Hunter V1.2 local power screening:
# - Census geocoder is the default no-key US geocoder.
# - Nominatim is fallback and requires a responsible user agent.
# - Overpass is used for OpenStreetMap power assets.
GEOCODING_PROVIDER=census
NOMINATIM_USER_AGENT=NOVAIONSiteHunterLocal/1.2
NOMINATIM_EMAIL=
OVERPASS_API_URL=https://overpass-api.de/api/interpreter
POWER_ASSET_SEARCH_RADII_MILES=1,3,5,10
TRANSMISSION_LINE_GEOJSON_PATH=
