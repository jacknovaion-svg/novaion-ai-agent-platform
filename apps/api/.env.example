APP_NAME="NOVAION AI Agent Platform"
APP_ENV=development

# Local frontend origins. In production, replace with your Vercel/custom domains.
# Example: https://novaion-web.vercel.app,https://www.novaion.ai
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Supabase/PostgreSQL connection string for SQLAlchemy + psycopg.
# Example: postgresql+psycopg://postgres:[PASSWORD]@[HOST]:5432/postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/novaion

# Keep false for stable customer demos. Set true to try real Playwright scraping.
ENABLE_LIVE_SCRAPING=false
PLAYWRIGHT_HEADLESS=true

# V1 has no authentication flow. This demo email is used for preferences and saved searches.
DEFAULT_USER_EMAIL=demo@novaion.ai
