# Backend API base URL. Local example:
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Production example:
# NEXT_PUBLIC_API_BASE_URL=https://novaion-api.onrender.com/api/v1

# V1 demo user. No password is required because auth is not implemented yet.
NEXT_PUBLIC_DEFAULT_USER_EMAIL=demo@novaion.ai
